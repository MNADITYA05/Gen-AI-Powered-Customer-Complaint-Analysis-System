# Copy this to .env for local development
# In HuggingFace Spaces, set these as Repository Secrets

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.vmieekmufrqpkqvhptjd.supabase.co:5432/postgres

# HuggingFace — needed to download private model weights at startup
HUGGINGFACE_TOKEN=hf_your_token_here

# JWT secret — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Admin credentials — change before deploying
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-in-production
